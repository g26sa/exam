using System;
using System.Data;
using System.Drawing;
using System.Text.RegularExpressions;
using System.Windows.Forms;
using Microsoft.Data.Sqlite;

namespace SqlConsolePlus
{
    public class Form1 : Form
    {
        private TextBox txtConnectionString;
        private TextBox txtQuery;
        private Button btnConnect;
        private Button btnExecute;
        private Button btnClear;
        private DataGridView dgvResult;
        private TextBox txtLog;
        private Label lblStatus;
        private Timer timerHighlight;

        private SqliteConnection _connection;

        public Form1()
        {
            InitializeComponent();
            InitHighlightTimer();
        }

        private void InitializeComponent()
        {
            this.Text = "SQL-консоль с подсветкой";
            this.StartPosition = FormStartPosition.CenterScreen;
            this.ClientSize = new Size(1050, 750);
            this.Font = new Font("Segoe UI", 10F);
            this.BackColor = Color.FromArgb(240, 240, 240);

            var lblConn = new Label { Text = "Строка подключения:", Location = new Point(10, 10), AutoSize = true };
            this.Controls.Add(lblConn);

            txtConnectionString = new TextBox
            {
                Location = new Point(10, 35),
                Size = new Size(900, 25),
                Text = "Data Source=database.db"
            };
            this.Controls.Add(txtConnectionString);

            btnConnect = CreateButton("Подключиться", 920, 30, 120, 32);
            btnConnect.Click += BtnConnect_Click;

            lblStatus = new Label { Text = "Статус: не подключено", Location = new Point(10, 75), AutoSize = true };
            this.Controls.Add(lblStatus);

            var lblQuery = new Label { Text = "SQL-запрос:", Location = new Point(10, 105), AutoSize = true };
            this.Controls.Add(lblQuery);

            txtQuery = new TextBox
            {
                Location = new Point(10, 130),
                Size = new Size(900, 150),
                Multiline = true,
                ScrollBars = ScrollBars.Vertical,
                AcceptsTab = true,
                Font = new Font("Consolas", 11F),
                Text = @"SELECT * FROM students 
WHERE group_name = 'ИС-21';"
            };
            txtQuery.TextChanged += TxtQuery_TextChanged;
            this.Controls.Add(txtQuery);

            btnExecute = CreateButton("Выполнить", 920, 130, 120, 32);
            btnExecute.Click += BtnExecute_Click;

            btnClear = CreateButton("Очистить", 920, 170, 120, 32);
            btnClear.Click += BtnClear_Click;

            dgvResult = new DataGridView
            {
                Location = new Point(10, 300),
                Size = new Size(1030, 320),
                ReadOnly = true,
                AutoSizeColumnsMode = DataGridViewAutoSizeColumnsMode.Fill,
                SelectionMode = DataGridViewSelectionMode.FullRowSelect
            };
            this.Controls.Add(dgvResult);

            txtLog = new TextBox
            {
                Location = new Point(10, 630),
                Size = new Size(1030, 110),
                Multiline = true,
                ScrollBars = ScrollBars.Vertical,
                ReadOnly = true,
                Font = new Font("Consolas", 9F)
            };
            this.Controls.Add(txtLog);
        }

        private Button CreateButton(string text, int x, int y, int width, int height)
        {
            var button = new Button
            {
                Text = text,
                Location = new Point(x, y),
                Size = new Size(width, height),
                BackColor = Color.FromArgb(47, 79, 111),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 10F, FontStyle.Bold)
            };
            button.FlatAppearance.BorderSize = 0;
            this.Controls.Add(button);
            return button;
        }

        private void InitHighlightTimer()
        {
            timerHighlight = new Timer();
            timerHighlight.Interval = 300;
            timerHighlight.Tick += TimerHighlight_Tick;
            timerHighlight.Start();
        }

        private void TxtQuery_TextChanged(object sender, EventArgs e)
        {
            timerHighlight.Stop();
            timerHighlight.Start();
        }

        private void TimerHighlight_Tick(object sender, EventArgs e)
        {
            timerHighlight.Stop();
            HighlightSqlSyntax();
        }

        private void HighlightSqlSyntax()
        {
            string sql = txtQuery.Text;
            txtQuery.SelectAll();
            txtQuery.SelectionBackColor = txtQuery.BackColor;
            txtQuery.SelectionColor = txtQuery.ForeColor;

            // Регулярное выражение для SQL-ключевых слов
            string pattern = @"\b(SELECT|INSERT|UPDATE|DELETE|FROM|WHERE|JOIN|ORDER|GROUP|HAVING|CREATE|DROP|ALTER|TABLE|INDEX|VIEW|ON|AS|IS|NOT|AND|OR|IN|LIKE|BETWEEN)\b";
            MatchCollection matches = Regex.Matches(sql, pattern, RegexOptions.IgnoreCase);

            foreach (Match match in matches)
            {
                txtQuery.Select(match.Index, match.Length);
                txtQuery.SelectionColor = Color.Blue;
                txtQuery.SelectionFont = new Font(txtQuery.Font.FontFamily, txtQuery.Font.Size, FontStyle.Bold);
            }

            txtQuery.SelectionStart = txtQuery.Text.Length;
            txtQuery.SelectionLength = 0;
        }

        private void BtnConnect_Click(object sender, EventArgs e)
        {
            try
            {
                _connection?.Dispose();
                _connection = new SqliteConnection(txtConnectionString.Text.Trim());
                _connection.Open();

                lblStatus.Text = "Статус: подключено";
                lblStatus.ForeColor = Color.Green;
                Log("Подключение открыто.");
            }
            catch (Exception ex)
            {
                lblStatus.Text = "Статус: ошибка";
                lblStatus.ForeColor = Color.Red;
                Log("Ошибка подключения: " + ex.Message);
            }
        }

        private void BtnExecute_Click(object sender, EventArgs e)
        {
            if (_connection == null || _connection.State != ConnectionState.Open)
            {
                Log("Сначала подключись к базе.");
                return;
            }

            string sql = txtQuery.Text.Trim();
            if (string.IsNullOrWhiteSpace(sql))
            {
                Log("SQL-запрос пустой.");
                return;
            }

            try
            {
                using var cmd = _connection.CreateCommand();
                cmd.CommandText = sql;

                if (sql.Trim().ToUpper().StartsWith("SELECT"))
                {
                    using var adapter = new SqliteDataAdapter(cmd.CommandText, _connection);
                    var table = new DataTable();
                    adapter.Fill(table);
                    dgvResult.DataSource = table;
                    Log("SELECT выполнен. Строк: " + table.Rows.Count);
                }
                else
                {
                    int rows = cmd.ExecuteNonQuery();
                    Log($"Команда выполнена. Затронуто строк: {rows}");
                }
            }
            catch (Exception ex)
            {
                Log("Ошибка SQL: " + ex.Message);
            }
        }

        private void BtnClear_Click(object sender, EventArgs e)
        {
            dgvResult.DataSource = null;
            txtLog.Clear();
            txtQuery.Clear();
            Log("Очищено.");
        }

        private void Log(string message)
        {
            txtLog.AppendText($"[{DateTime.Now:HH:mm:ss}] {message}\r\n");
        }

        protected override void OnFormClosing(FormClosingEventArgs e)
        {
            timerHighlight?.Stop();
            _connection?.Dispose();
            base.OnFormClosing(e);
        }
    }
}
